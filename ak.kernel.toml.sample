[kernel]
src_dir = "kernel"
arch = "arm64"
toolchain_prefix = "aarch64-linux-gnu-"
targets = ["Image", "dtbs", "modules"]
# build_log = "kernel-build.log"

[[kernel.remote]]
name = "upstream"
url = "https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git"
branch = "linux-6.6.y"
checkout = false

[[kernel.remote]]
name = "vendor"
url = "https://github.com/example/vendor-linux.git"
branch = "vendor-6.6"
checkout = true

[[kernel.defconfig]]
name = "my_board"
config = "configs/my_board.config"

# [[kernel.defconfig]]
# name = "another_board"
# config = "configs/another_board.config"
